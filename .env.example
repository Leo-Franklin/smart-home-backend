# ─── 网络 ───────────────────────────────────
NETWORK_RANGE=auto                     # auto: 自动检测本机网段; 或手动指定如 192.168.1.0/24
SCAN_INTERVAL_SECONDS=60

# ─── 摄像头 (TP-Link IPC682F-A4) ────────────
CAMERA_ONVIF_USER=admin
CAMERA_ONVIF_PASSWORD=your_camera_password

# ─── 存储模式 ─────────────────────────────────
# local: 录制文件保存到本机（无NAS时使用）
# mount: 通过 Docker 挂载写入 NAS
# smb:   通过 SMB 协议推送到 NAS
NAS_MODE=local
LOCAL_STORAGE_PATH=./data/recordings    # local 模式: 本地存储目录

# ─── 绿联 NAS（NAS_MODE=mount 或 smb 时填写）────
NAS_MOUNT_PATH=/nas/cameras      # mount 模式: 容器内挂载路径
NAS_SMB_HOST=192.168.1.xxx       # smb 模式: NAS IP
NAS_SMB_SHARE=Backup             # smb 模式: 共享文件夹名
NAS_SMB_USER=nas_username
NAS_SMB_PASSWORD=nas_password

# ─── 录制 ────────────────────────────────────
RECORDING_TEMP_DIR=/tmp/recordings
RECORDING_SEGMENT_SECONDS=1800
RECORDING_RETENTION_DAYS=30

# ─── 数据库 ──────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/smart_home.db

# ─── 应用 ────────────────────────────────────
# Generate strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_random_secret_here_at_least_32_chars
ADMIN_USERNAME=admin
# Generate bcrypt hash: python -c "from passlib.context import CryptContext; print(CryptContext(['bcrypt']).hash('your_password'))"
# Or use a strong plaintext password (less secure)
ADMIN_PASSWORD=your_strong_password_here
LOG_LEVEL=INFO
DEBUG=false

# ─── CORS ────────────────────────────────────
# Comma-separated list of allowed origins (independent of DEBUG flag)
CORS_ALLOW_ORIGINS=http://localhost:5173
